# Copy to .env.local and fill in. Never commit .env.local — it holds secrets.

# ---------------------------------------------------------------------------
# Auth.js (NextAuth) — editor sign-in via magic link
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Postgres for the @auth/pg-adapter (note: no +psycopg2 dialect prefix)
DATABASE_URL=postgresql://lexhaiti:lexhaiti@localhost:5432/lexhaiti

# ---------------------------------------------------------------------------
# Email — Mailpit dev SMTP catcher (UI at http://localhost:8025)
# Replace with your real SMTP creds in production.
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=no-reply@lexhaiti.local

# ---------------------------------------------------------------------------
# Backend API — relative path so Next.js proxies it (see next.config.ts rewrites)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api/v1
# Used server-side by Next.js rewrites to reach the backend. Point at your
# deployed backend URL in production (e.g. https://api.lexhaiti.ht).
LEXHAITI_API_INTERNAL_URL=http://localhost:8000
